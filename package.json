{
  "name": "meghna-hugo",
  "version": "2.2.0",
  "license": "MIT",
  "author": "gethugothemes",
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "cheerio": "^1.2.0",
    "cspell": "^10.0.1",
    "cssnano": "^7.1.0",
    "husky": "^8.0.3",
    "lighthouse": "^13.1.0",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "lint-staged": "^12.5.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^34.0.0",
    "textlint": "^15.7.1",
    "textlint-rule-common-misspellings": "^1.0.1",
    "textlint-rule-no-doubled-conjunction": "^3.0.1",
    "textlint-rule-no-start-duplicated-conjunction": "^2.0.2",
    "textlint-rule-terminology": "^5.2.16",
    "textlint-rule-write-good": "^2.0.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "{assets,static}/**/*.{css,scss,sass}": [
      "stylelint --fix --allow-empty-input",
      "prettier --write"
    ]
  },
  "scripts": {
    "dev": "hugo server --buildDrafts --buildFuture --disableFastRender --forceSyncStatic --baseURL http://localhost:1313/ --bind 127.0.0.1 --port 1313",
    "build": "hugo --gc --minify --templateMetrics --templateMetricsHints --buildExpired --forceSyncStatic",
    "hugo:build": "hugo --gc --minify",
    "audit": "node ./tools/run-audit.js",
    "audit:report": "node ./tools/lighthouse-report.js",
    "bootstrap:purge": "node ./tools/purge-bootstrap.mjs",
    "test": "hugo server --disableFastRender --navigateToChanged --templateMetrics --templateMetricsHints --buildExpired --watch --forceSyncStatic -e production --minify",
    "test:seo": "hugo --gc --minify --templateMetrics --templateMetricsHints --buildExpired --forceSyncStatic --cleanDestinationDir && npm run test:seo:assert",
    "test:seo:assert": "vitest run tests/seo-build.test.mjs",
    "lint:css": "stylelint \"**/*.{css,scss,sass}\" --allow-empty-input",
    "lint:css:fix": "stylelint \"**/*.{css,scss,sass}\" --fix --allow-empty-input",
    "lint:text:style": "textlint \"content/**/*.md\"",
    "lint:text:spell": "cspell lint \"content/**/*.md\" --no-progress --show-context --show-suggestions",
    "lint:text": "npm run lint:text:style && npm run lint:text:spell",
    "lint:text:debug": "powershell -NoProfile -Command \"$files = Get-ChildItem 'content' -Recurse -Filter *.md; Write-Host ('content lint: checking ' + $files.Count + ' markdown files under content/'); $files | ForEach-Object { Write-Host $_.FullName }; Write-Host ''; Write-Host '--- textlint --debug ---'; npx textlint 'content/**/*.md' --debug; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; Write-Host ''; Write-Host '--- cspell -v ---'; npx cspell lint 'content/**/*.md' -v --show-context --show-suggestions\"",
    "lint:text:fix": "textlint --fix \"content/**/*.md\"",
    "lint": "npm run lint:css && npm run lint:text",
    "allchecks": "npm run format:check && npm run lint && npm run test:seo && npm run audit",
    "format": "prettier --write \"**/*.{css,scss,sass}\"",
    "format:check": "prettier --check \"**/*.{css,scss,sass}\"",
    "prepare": "husky install",
    "dev:example": "cd exampleSite; hugo server --themesDir ../..",
    "update-modules": "node ./scripts/clearModules.js && hugo mod clean --all && hugo mod get -u ./... && hugo mod tidy",
    "project-setup": "node ./scripts/projectSetup.js",
    "theme-setup": "node ./scripts/themeSetup.js"
  }
}
